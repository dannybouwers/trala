---
import { getCollection, render } from 'astro:content';
import DocsLayout from '../../layouts/DocsLayout.astro';

export async function getStaticPaths() {
  const docs = await getCollection('docs');
  
  // Filter out README.md - it's handled by the index.astro page
  return docs
    .filter(doc => doc.id !== 'README.md')
    .map((doc) => ({
      params: { slug: doc.id.replace('.md', '') },
      props: { doc },
    }));
}

const { doc } = Astro.props;
const { Content } = await render(doc);

const currentPath = `/docs/${doc.id.replace('.md', '')}`;
---

<DocsLayout title={doc.data.title || doc.id.replace('.md', '')} currentPath={currentPath}>
  <Content />
</DocsLayout>
